<script type='text/javascript'>
// <![CDATA[
(function() {
    'use strict';
    
    const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbznDXojF_XNAbx4Nx97qrsDKsCsEE3Z-AdxlHRNJKXBjP3szuR2saIUZ0rg4T1obq-R/exec";
    
    let knowledgeBase = {};
    let pendingQuestions = [];
    let currentCategory = 'general';
    let waitingForAnswer = false;
    let lastQuestion = '';
    let isProcessing = false;
    let currentMatches = [];
    let currentMatchIndex = 0;
    let currentUserQuestion = '';

    function init() {
        console.log('🚀 চ্যাটবট শুরু...');
        loadFromLocalStorage();
        loadFromSheet();
        setupCategoryListeners();
        updatePendingCount();
        updateOnlineStatus();
        if (window.innerWidth <= 768) document.getElementById('sidebarPanel').classList.add('collapsed');
        if (!localStorage.getItem('chatbot_help_shown')) { setTimeout(showHelp, 2000); localStorage.setItem('chatbot_help_shown', 'true'); }
    }

    function updateOnlineStatus() {
        const d = document.querySelector('.status-dot'), t = document.querySelector('.status-indicator');
        if (navigator.onLine) { if(d) d.style.background='#10b981'; if(t) t.innerHTML='<span class="status-dot"></span> অনলাইন'; }
        else { if(d) d.style.background='#f59e0b'; if(t) t.innerHTML='<span class="status-dot" style="background:#f59e0b"></span> অফলাইন মোড'; }
    }
    window.addEventListener('online', updateOnlineStatus); window.addEventListener('offline', updateOnlineStatus);

    window.toggleSidebar = function() {
        const s = document.getElementById('sidebarPanel'); s.classList.toggle('collapsed');
        if (window.innerWidth <= 768) s.style.boxShadow = s.classList.contains('collapsed') ? 'none' : '0 0 80px rgba(0,0,0,0.6)';
    };

    function setupCategoryListeners() {
        document.querySelectorAll('.category-item').forEach(item => {
            item.addEventListener('click', function() {
                document.querySelectorAll('.category-item').forEach(i => { i.classList.remove('active'); const st = i.querySelector('.category-stats'); if(st) st.remove(); });
                this.classList.add('active');
                if (!this.querySelector('.category-stats')) { const sp = document.createElement('span'); sp.className='category-stats'; sp.textContent='সক্রিয়'; this.appendChild(sp); }
                if (waitingForAnswer) { waitingForAnswer = false; lastQuestion = ''; currentMatches = []; currentMatchIndex = 0; }
                currentCategory = this.dataset.category;
                document.getElementById('currentCategory').textContent = this.textContent.replace('সক্রিয়','').trim();
                showCategoryGreeting();
                if (window.innerWidth <= 768) document.getElementById('sidebarPanel').classList.add('collapsed');
            });
        });
    }

    function showCategoryGreeting() {
        const g = { 'general': '👋 সাধারণ জিজ্ঞাসায় স্বাগতম!', 'technology': '💻 প্রযুক্তি বিভাগে স্বাগতম!', 'education': '📚 শিক্ষা বিভাগে স্বাগতম!', 'health': '🏥 স্বাস্থ্য বিভাগে স্বাগতম!', 'science': '🔬 বিজ্ঞান বিভাগে স্বাগতম!' };
        addBotMessage(g[currentCategory] || g['general']);
    }

    window.showHelp = function() { const t = document.getElementById('helpTooltip'); t.style.display='block'; t.style.animation='fadeInUp 0.5s ease'; clearTimeout(window.helpTimeout); window.helpTimeout = setTimeout(hideHelp, 8000); };
    window.hideHelp = function() { const t = document.getElementById('helpTooltip'); t.style.animation='fadeIn 0.3s ease reverse'; setTimeout(() => t.style.display='none', 300); };

    function normalizeText(text) { return text.toString().toLowerCase().trim().replace(/[?।!.,]/g, '').replace(/\s+/g, ' '); }
    function getWords(text) { return normalizeText(text).split(/\s+/).filter(w => w.length > 1).filter(w => !isStopWord(w)); }
    function isStopWord(word) {
        const sw = ['একটি','একটা','এই','ওই','এবং','অথবা','কি','কী','যে','যা','হয়','ছে','ছি','তে','র','ের','কে','the','a','an','is','are','was','were','of','in','on','at','to','for','with','আমি','তুমি','আপনি','সে','তা','তারা','আমার','তোমার','তার','এইটা','ওইটা','করে','করেন','হবে','থাকে','থাকেন'];
        return sw.includes(word);
    }

    function getWordMatchScore(userText, storedQuestion) {
        const uw = getWords(userText), sw = getWords(storedQuestion);
        if (!uw.length || !sw.length) return 0;
        let mc = 0;
        for (let a of uw) for (let b of sw) { if (a === b) { mc++; break; } else if (a.length >= 3 && b.length >= 3 && (b.includes(a) || a.includes(b))) { mc += 0.5; break; } }
        return uw.length > 0 ? mc / uw.length : 0;
    }

    function findBestMatch(question) {
        const all = [];
        for (let cat in knowledgeBase) for (let q in knowledgeBase[cat]) {
            const score = getWordMatchScore(question, q);
            if (score > 0) all.push({ category: cat, question: q, answer: knowledgeBase[cat][q], score });
        }
        all.sort((a, b) => b.score - a.score);
        return all;
    }

    function loadFromLocalStorage() { try { const d = localStorage.getItem('chatbot_knowledge'); if (d) knowledgeBase = JSON.parse(d); } catch(e) {} }
    function saveToLocalStorage() { try { localStorage.setItem('chatbot_knowledge', JSON.stringify(knowledgeBase)); } catch(e) {} }
    function savePendingToLocal() { try { localStorage.setItem('chatbot_pending', JSON.stringify(pendingQuestions)); } catch(e) {} }
    function updatePendingCount() { const c = pendingQuestions.length; document.getElementById('pendingCount').textContent = c; document.getElementById('adminPendingCount').textContent = c; }

    async function loadFromSheet() {
        try {
            const url = `${SCRIPT_URL}?action=getAll&t=${new Date().getTime()}`;
            const res = await fetch(url); const result = await res.json();
            if (result && result.success && result.data) {
                if (result.data.records) { result.data.records.forEach(r => { if (!r.question || !r.answer) return; const cat = r.category || 'general'; if (!knowledgeBase[cat]) knowledgeBase[cat] = {}; knowledgeBase[cat][normalizeText(r.question)] = r.answer; }); saveToLocalStorage(); }
                if (result.data.pending) { pendingQuestions = result.data.pending; savePendingToLocal(); updatePendingCount(); }
            }
        } catch(e) { console.log('⚠️ শীট লোড ব্যর্থ'); }
    }

    async function saveToSheet(action, category, question, answer) {
        try {
            const data = { action, category: category || 'general', question: question || '', answer: answer || '' };
            const res = await fetch(SCRIPT_URL, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: JSON.stringify(data) });
            return (await res.json()).success;
        } catch(e) {
            try { await fetch(SCRIPT_URL, { method: 'POST', mode: 'no-cors', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: JSON.stringify({ action, category, question, answer }) }); return true; } catch(e2) { return false; }
        }
    }

    function showProcessingIndicator(text) {
        const c = document.getElementById('messagesContainer');
        const d = document.createElement('div'); d.className='message-row bot'; d.id='processingIndicator';
        d.innerHTML = `<div class="bot-avatar small"><i class="fas fa-robot"></i></div><div class="processing-indicator"><div class="brain-wave"><span></span><span></span><span></span><span></span><span></span></div><span class="processing-text">${text||'চিন্তা করছি...'}</span></div>`;
        c.appendChild(d); c.scrollTop = c.scrollHeight;
    }
    function updateProcessingText(text) { const el = document.getElementById('processingIndicator'); if (el) { const t = el.querySelector('.processing-text'); if(t) t.textContent = text; } }
    function hideProcessingIndicator() { const el = document.getElementById('processingIndicator'); if (el) el.remove(); }

    function hideWelcome() {
        const w = document.getElementById('welcomeSection');
        if (w) { w.style.opacity='0'; w.style.transform='translateY(-20px)'; w.style.transition='all 0.5s ease'; setTimeout(() => { if(w.parentNode) w.remove(); }, 500); }
    }

    function addMessage(text, isUser, extraClass) {
        hideWelcome();
        const c = document.getElementById('messagesContainer');
        const r = document.createElement('div'); r.className = `message-row ${isUser ? 'user' : 'bot'}`;
        const ts = new Date().toLocaleTimeString('bn-BD', { hour: '2-digit', minute: '2-digit' });
        if (isUser) r.innerHTML = `<div class="message-bubble ${extraClass||''}">${escapeHtml(text)}<div class="message-timestamp"><i class="fas fa-check" style="font-size:0.6rem;"></i> ${ts}</div></div>`;
        else r.innerHTML = `<div class="bot-avatar"><i class="fas fa-robot"></i></div><div class="message-bubble ${extraClass||''}">${text}<div class="message-timestamp"><i class="fas fa-clock" style="font-size:0.6rem;"></i> ${ts}</div></div>`;
        c.appendChild(r); c.scrollTop = c.scrollHeight; r.scrollIntoView({ behavior: 'smooth', block: 'end' });
    }
    function addBotMessage(text, extraClass) { addMessage(text, false, extraClass); }
    function escapeHtml(text) { const d = document.createElement('div'); d.textContent = text; return d.innerHTML; }
    function getCategoryName(cat) { const n = { 'general': 'সাধারণ জিজ্ঞাসা', 'technology': 'প্রযুক্তি', 'education': 'শিক্ষা', 'health': 'স্বাস্থ্য', 'science': 'বিজ্ঞান' }; return n[cat] || cat; }

    // ★★★ স্মার্ট রেসপন্স ★★★
    function showSmartMatchResponse(userQuestion, matches, matchIndex) {
        const match = matches[matchIndex];
        let html = `🔍 <strong>আপনার প্রশ্নের জন্য এই উত্তরটি পেয়েছি:</strong><br/><br/>`;
        html += `<strong>💡 উত্তর:</strong><br/>${match.answer}<br/><br/>`;
        html += `<em>এই উত্তরটি কি আপনার প্রশ্নের জন্য সঠিক?</em><br/><br/>`;
        html += `<div class="smart-response-btns">`;
        html += `<button class="smart-btn yes-btn" onclick="handleSmartYes()"><i class="fas fa-check-circle"></i> হ্যাঁ, সঠিক</button>`;
        html += `<button class="smart-btn no-btn" onclick="handleSmartNo()"><i class="fas fa-times-circle"></i> না, ভুল</button>`;
        html += `<button class="smart-btn retry-btn" onclick="handleSmartRetry()"><i class="fas fa-redo"></i> আবার প্রশ্ন করুন</button>`;
        html += `<button class="smart-btn teach-btn" onclick="handleSmartTeach()"><i class="fas fa-chalkboard-teacher"></i> তুমি জানলে উত্তর দাও</button>`;
        html += `</div>`;
        addBotMessage(html);
    }

    window.handleSmartYes = function() {
        currentMatches = []; currentMatchIndex = 0; waitingForAnswer = false; lastQuestion = '';
        addBotMessage(`✅ <strong>দারুণ! আমি খুশি যে উত্তরটি সঠিক ছিল!</strong><br/><br/>😊 নতুন কোনো প্রশ্ন থাকলে বলুন, আমি সাহায্য করতে প্রস্তুত!`);
    };

    window.handleSmartNo = function() {
        currentMatchIndex++;
        if (currentMatchIndex < currentMatches.length) {
            addBotMessage(`🔍 <strong>ঠিক আছে, তাহলে পরবর্তী সম্ভাব্য উত্তরটি দেখুন:</strong>`);
            showSmartMatchResponse(currentUserQuestion, currentMatches, currentMatchIndex);
        } else {
            currentMatches = []; currentMatchIndex = 0;
            addBotMessage(`😔 <strong>দুঃখিত, আমার কাছে আর কোনো উত্তর নেই এই প্রশ্নের জন্য।</strong><br/><br/>📋 প্রশ্নটি সংরক্ষণ করে রাখছি।`);
            saveAsPending(currentUserQuestion);
        }
    };

    window.handleSmartRetry = function() {
        currentMatches = []; currentMatchIndex = 0; waitingForAnswer = false; lastQuestion = ''; currentUserQuestion = '';
        addBotMessage(`👌 <strong>ঠিক আছে! নতুন প্রশ্ন করুন, আমি উত্তর খোঁজার চেষ্টা করবো।</strong><br/><br/><em>আপনার প্রশ্ন লিখুন...</em>`);
        document.getElementById('userInput').focus();
    };

    window.handleSmartTeach = function() {
        currentMatches = []; currentMatchIndex = 0; waitingForAnswer = true; lastQuestion = currentUserQuestion;
        addBotMessage(`📚 <strong>দারুণ! দয়া করে আপনার প্রশ্নের সঠিক উত্তরটি লিখুন।</strong><br/><br/>✍️ <em>পরবর্তী মেসেজটি উত্তর হিসেবে সংরক্ষণ করবো।</em>`);
        document.getElementById('userInput').focus();
    };

    async function saveAsPending(question) {
        await saveToSheet('addPending', currentCategory, question, '');
        pendingQuestions.push({ category: currentCategory, question, timestamp: new Date().toISOString() });
        savePendingToLocal(); updatePendingCount();
        waitingForAnswer = true; lastQuestion = question;
        let html = `<div class="smart-response-btns">`;
        html += `<button class="smart-btn teach-btn" onclick="handleSmartTeach()"><i class="fas fa-chalkboard-teacher"></i> তুমি জানলে উত্তর দাও</button>`;
        html += `<button class="smart-btn skip-btn-style" onclick="handleSmartRetry()"><i class="fas fa-forward"></i> স্কিপ করে নতুন প্রশ্ন</button>`;
        html += `</div>`;
        addBotMessage(html);
    }

    // ★★★ প্রশ্ন প্রসেসিং ★★★
    async function processQuestion(userQuestion) {
        if (!userQuestion || userQuestion.trim() === '') { addBotMessage('😊 দয়া করে একটি প্রশ্ন লিখুন। আমি আপনার সাহায্যের জন্য প্রস্তুত আছি!'); return; }
        
        if (waitingForAnswer) {
            // আগের প্রশ্নের উত্তর হিসেবে আসছে
            const answer = userQuestion;
            const prevQuestion = lastQuestion;
            waitingForAnswer = false; lastQuestion = ''; currentMatches = []; currentMatchIndex = 0;
            
            updateProcessingText('আপনার উত্তর সংরক্ষণ করছি...');
            await new Promise(r => setTimeout(r, 400));
            
            await saveToSheet('addRecord', currentCategory, prevQuestion, answer);
            if (!knowledgeBase[currentCategory]) knowledgeBase[currentCategory] = {};
            knowledgeBase[currentCategory][normalizeText(prevQuestion)] = answer;
            saveToLocalStorage();
            
            hideProcessingIndicator();
            addBotMessage(`🎉 <strong>অসাধারণ! উত্তরটি সফলভাবে সংরক্ষণ করেছি।</strong><br/><br/>📝 <strong>প্রশ্ন:</strong> ${prevQuestion}<br/>💡 <strong>উত্তর:</strong> ${answer}<br/><br/><em>এখন থেকে এই প্রশ্নের উত্তর আমি জানবো! 😊</em>`);
            return;
        }
        
        currentUserQuestion = userQuestion;
        const matches = findBestMatch(userQuestion);
        
        if (matches.length > 0 && matches[0].score >= 0.25) {
            currentMatches = matches; currentMatchIndex = 0;
            updateProcessingText('উত্তর খুঁজে পেয়েছি!');
            await new Promise(r => setTimeout(r, 400));
            hideProcessingIndicator();
            showSmartMatchResponse(userQuestion, matches, 0);
        } else {
            updateProcessingText('সংরক্ষণ করছি...');
            await new Promise(r => setTimeout(r, 300));
            hideProcessingIndicator();
            addBotMessage(`🤔 <strong>মাফ করবেন, আমি "${userQuestion}" এর উত্তর জানি না।</strong><br/><br/>📋 প্রশ্নটি "<strong>${getCategoryName(currentCategory)}</strong>" বিষয়ে সংরক্ষণ করছি।`);
            await saveAsPending(userQuestion);
        }
    }

    window.askQuestion = function(q) { document.getElementById('userInput').value = q; document.getElementById('userInput').focus(); handleSend(); };

    window.handleSend = async function() {
        if (isProcessing) return;
        const input = document.getElementById('userInput');
        const question = input.value.trim();
        if (!question) { input.placeholder = '⚠️ প্রথমে একটি প্রশ্ন লিখুন!'; input.focus(); setTimeout(() => input.placeholder = 'এখানে আপনার প্রশ্ন লিখুন...', 2000); return; }
        
        isProcessing = true;
        addMessage(question, true);
        input.value = ''; input.focus();
        
        showProcessingIndicator('আপনার প্রশ্ন বিশ্লেষণ করছি...');
        await new Promise(r => setTimeout(r, 500 + Math.random() * 300));
        updateProcessingText('শব্দ মিলিয়ে উত্তর খুঁজছি...');
        await new Promise(r => setTimeout(r, 400 + Math.random() * 200));
        
        await processQuestion(question);
        hideProcessingIndicator();
        isProcessing = false;
    };

    // অ্যাডমিন প্যানেল
    window.openAdminPanel = function() { document.getElementById('adminModal').classList.add('active'); renderPendingQuestions(); document.body.style.overflow = 'hidden'; document.addEventListener('keydown', handleEscKey); };
    window.closeAdminPanel = function() { document.getElementById('adminModal').classList.remove('active'); document.body.style.overflow = ''; document.removeEventListener('keydown', handleEscKey); };
    function handleEscKey(e) { if (e.key === 'Escape') closeAdminPanel(); }

    function renderPendingQuestions() {
        const c = document.getElementById('pendingQuestionsList');
        if (!pendingQuestions.length) {
            c.innerHTML = `<p style='color:#64748b;text-align:center;padding:40px 20px;font-size:1.05rem;'><i class='fas fa-check-circle' style='font-size:3rem;color:#10b981;display:block;margin-bottom:14px;'></i><strong>সব উত্তর দিয়ে ফেলেছেন!</strong><br/><span style='font-size:0.9rem;'>কোনো অপেক্ষমাণ প্রশ্ন নেই 🎉</span></p>`;
            return;
        }
        c.innerHTML = pendingQuestions.map((item, i) => `
            <div class="pending-question">
                <div class="question-text"><span class="category-tag">${getCategoryName(item.category)}</span><span>${escapeHtml(item.question)}</span></div>
                <textarea class="answer-input" placeholder="✍️ উত্তর লিখুন..." id="answerInput${i}" rows="3"></textarea>
                <div class="button-group">
                    <button class="save-answer-btn" onclick="saveAnswerFromAdmin(${i})"><i class="fas fa-save"></i> সংরক্ষণ</button>
                    <button class="delete-btn" onclick="removePending(${i})"><i class="fas fa-trash"></i> মুছুন</button>
                </div>
            </div>`).join('');
    }

    window.saveAnswerFromAdmin = async function(index) {
        const inp = document.getElementById(`answerInput${index}`);
        const ans = inp.value.trim();
        if (!ans) { inp.style.borderColor='#f43f5e'; inp.style.boxShadow='0 0 0 4px rgba(244,63,94,0.1)'; inp.placeholder='⚠️ উত্তর লিখুন!'; inp.focus(); setTimeout(() => { inp.style.borderColor='#e2e8f0'; inp.style.boxShadow='none'; inp.placeholder='✍️ উত্তর লিখুন...'; }, 2500); return; }
        const item = pendingQuestions[index];
        await saveToSheet('addRecord', item.category, item.question, ans);
        if (!knowledgeBase[item.category]) knowledgeBase[item.category] = {};
        knowledgeBase[item.category][normalizeText(item.question)] = ans;
        saveToLocalStorage();
        if (waitingForAnswer && lastQuestion === item.question) { waitingForAnswer = false; lastQuestion = ''; currentMatches = []; }
        pendingQuestions.splice(index, 1); savePendingToLocal(); updatePendingCount(); renderPendingQuestions();
    };

    window.removePending = function(index) {
        const item = pendingQuestions[index];
        if (confirm('🗑️ মুছে ফেলতে চান?')) {
            if (waitingForAnswer && lastQuestion === item.question) { waitingForAnswer = false; lastQuestion = ''; currentMatches = []; }
            pendingQuestions.splice(index, 1); savePendingToLocal(); updatePendingCount(); renderPendingQuestions();
        }
    };

    document.getElementById('userInput').addEventListener('keydown', function(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); handleSend(); } });
    document.getElementById('adminModal').addEventListener('click', function(e) { if (e.target === this) closeAdminPanel(); });
    document.addEventListener('click', function(e) { const t = document.getElementById('helpTooltip'); if (t.style.display === 'block' && !t.contains(e.target) && !e.target.closest('.subject-chip[onclick*="showHelp"]')) hideHelp(); });
    window.addEventListener('resize', function() { const s = document.getElementById('sidebarPanel'); if (window.innerWidth > 768) { s.style.boxShadow='none'; s.classList.remove('collapsed'); } else s.classList.add('collapsed'); });
    window.addEventListener('beforeunload', function() { waitingForAnswer = false; lastQuestion = ''; currentMatches = []; currentMatchIndex = 0; });

    window.testSheetConnection = async function() { console.log('🧪 টেস্ট...'); await saveToSheet('addPending', 'general', 'টেস্ট ' + new Date().toISOString(), ''); console.log('✅ সম্পন্ন'); };

    init();
    console.log('✅ চ্যাটবট প্রস্তুত! 🚀');
})();
// ]]>
</script>
</body>
