<script type='text/javascript'>
// <![CDATA[
(function() {
    'use strict';
    
    // Google Apps Script URL - অপরিবর্তিত
    const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbznDXojF_XNAbx4Nx97qrsDKsCsEE3Z-AdxlHRNJKXBjP3szuR2saIUZ0rg4T1obq-R/exec";
    
    // ডাটাবেজ - অপরিবর্তিত
    let knowledgeBase = {};
    let pendingQuestions = [];
    let currentCategory = 'general';
    let waitingForAnswer = false;
    let lastQuestion = '';
    let isProcessing = false;

    // ইনিশিয়ালাইজ - অপরিবর্তিত
    function init() {
        console.log('🚀 চ্যাটবট শুরু হচ্ছে...');
        loadFromLocalStorage();
        loadFromSheet();
        setupCategoryListeners();
        updatePendingCount();
        updateOnlineStatus();
        setupInputListeners();
        
        if (window.innerWidth <= 768) {
            document.getElementById('sidebarPanel').classList.add('collapsed');
        }
        
        if (!localStorage.getItem('chatbot_help_shown')) {
            setTimeout(showHelp, 2000);
            localStorage.setItem('chatbot_help_shown', 'true');
        }
    }

    function updateOnlineStatus() {
        const statusDot = document.querySelector('.status-dot');
        const statusText = document.querySelector('.status-indicator');
        if (navigator.onLine) {
            if (statusDot) statusDot.style.background = '#10b981';
            if (statusText) statusText.innerHTML = '<span class="status-dot"></span> অনলাইন';
        } else {
            if (statusDot) statusDot.style.background = '#f59e0b';
            if (statusText) statusText.innerHTML = '<span class="status-dot" style="background:#f59e0b"></span> অফলাইন মোড';
        }
    }

    window.addEventListener('online', updateOnlineStatus);
    window.addEventListener('offline', updateOnlineStatus);

    function setupInputListeners() {
        const input = document.getElementById('userInput');
        
        input.addEventListener('focus', function() {
            document.getElementById('inputWrapper').style.transform = 'scale(1.01)';
        });
        
        input.addEventListener('blur', function() {
            document.getElementById('inputWrapper').style.transform = 'scale(1)';
        });
    }

    window.toggleSidebar = function() {
        const sidebar = document.getElementById('sidebarPanel');
        sidebar.classList.toggle('collapsed');
        
        if (window.innerWidth <= 768) {
            if (!sidebar.classList.contains('collapsed')) {
                sidebar.style.boxShadow = '0 0 80px rgba(0,0,0,0.6)';
            } else {
                sidebar.style.boxShadow = 'none';
            }
        }
    };

    function setupCategoryListeners() {
        document.querySelectorAll('.category-item').forEach(item => {
            item.addEventListener('click', function() {
                document.querySelectorAll('.category-item').forEach(i => {
                    i.classList.remove('active');
                    const statsEl = i.querySelector('.category-stats');
                    if (statsEl) statsEl.remove();
                });
                this.classList.add('active');
                
                if (!this.querySelector('.category-stats')) {
                    const statsSpan = document.createElement('span');
                    statsSpan.className = 'category-stats';
                    statsSpan.textContent = 'সক্রিয়';
                    this.appendChild(statsSpan);
                }
                
                // ক্যাটাগরি পরিবর্তন হলে স্কিপ স্টেট রিসেট
                if (waitingForAnswer) {
                    waitingForAnswer = false;
                    lastQuestion = '';
                    console.log('🔄 ক্যাটাগরি পরিবর্তন - স্কিপ স্টেট রিসেট');
                }
                
                currentCategory = this.dataset.category;
                document.getElementById('currentCategory').textContent = this.textContent.replace('সক্রিয়', '').trim();
                showCategoryGreeting();
                
                if (window.innerWidth <= 768) {
                    document.getElementById('sidebarPanel').classList.add('collapsed');
                }
            });
        });
    }

    function showCategoryGreeting() {
        const greetings = {
            'general': '👋 সাধারণ জিজ্ঞাসা বিভাগে আপনাকে স্বাগতম! নির্দ্বিধায় যেকোনো প্রশ্ন করতে পারেন।',
            'technology': '💻 প্রযুক্তি জগতে স্বাগতম! টেক সম্পর্কিত আপনার সব প্রশ্নের উত্তর দিতে আমি প্রস্তুত।',
            'education': '📚 শিক্ষা বিভাগে স্বাগতম! পড়াশোনা নিয়ে যেকোনো প্রশ্ন করুন, আমি সাহায্য করবো।',
            'health': '🏥 সুস্থ থাকুন! স্বাস্থ্য বিষয়ক আপনার প্রশ্নের উত্তর দিতে আমি এখানে আছি।',
            'science': '🔬 বিজ্ঞানের রোমাঞ্চকর বিশ্বে স্বাগতম! বৈজ্ঞানিক কৌতূহল নিয়ে প্রশ্ন করুন।'
        };
        addBotMessage(greetings[currentCategory] || greetings['general']);
    }

    window.showHelp = function() {
        const tooltip = document.getElementById('helpTooltip');
        tooltip.style.display = 'block';
        tooltip.style.animation = 'fadeInUp 0.5s ease';
        
        clearTimeout(window.helpTimeout);
        window.helpTimeout = setTimeout(hideHelp, 8000);
    };

    window.hideHelp = function() {
        const tooltip = document.getElementById('helpTooltip');
        tooltip.style.animation = 'fadeIn 0.3s ease reverse';
        setTimeout(() => {
            tooltip.style.display = 'none';
        }, 300);
    };

    // টেক্সট নর্মালাইজ - অপরিবর্তিত
    function normalizeText(text) {
        return text.toString().toLowerCase().trim()
            .replace(/[?।!.,]/g, '').replace(/\s+/g, ' ');
    }

    // শব্দে ভাঙা - ওয়ার্ড ম্যাচিং এর জন্য
    function getWords(text) {
        return normalizeText(text)
            .split(/\s+/)
            .filter(word => word.length > 1) // ১ অক্ষরের শব্দ বাদ
            .filter(word => !isStopWord(word)); // সাধারণ শব্দ বাদ
    }

    // স্টপ ওয়ার্ড (সাধারণ বাংলা শব্দ যা অর্থবহ নয়)
    function isStopWord(word) {
        const stopWords = ['একটি', 'একটা', 'এই', 'ওই', 'এবং', 'অথবা', 'কি', 'কী', 'যে', 'যা', 
                          'হয়', 'ছে', 'ছি', 'তে', 'র', 'ের', 'কে', 'the', 'a', 'an', 'is', 
                          'are', 'was', 'were', 'of', 'in', 'on', 'at', 'to', 'for', 'with',
                          'আমি', 'তুমি', 'আপনি', 'সে', 'তা', 'তারা', 'আমার', 'তোমার', 'তার',
                          'এইটা', 'ওইটা', 'করে', 'করেন', 'হবে', 'থাকে', 'থাকেন'];
        return stopWords.includes(word);
    }

    // ওয়ার্ড ম্যাচিং স্কোর - দুটি টেক্সটের মধ্যে কত শব্দ মিলছে
    function getWordMatchScore(userText, storedQuestion) {
        const userWords = getWords(userText);
        const storedWords = getWords(storedQuestion);
        
        if (userWords.length === 0 || storedWords.length === 0) return 0;
        
        let matchCount = 0;
        const matchedWords = [];
        
        for (let userWord of userWords) {
            for (let storedWord of storedWords) {
                // সরাসরি মিল
                if (userWord === storedWord) {
                    matchCount++;
                    matchedWords.push(userWord);
                    break;
                }
                // আংশিক মিল (শব্দের অংশ)
                if (userWord.length >= 3 && storedWord.length >= 3) {
                    if (storedWord.includes(userWord) || userWord.includes(storedWord)) {
                        matchCount += 0.5;
                        break;
                    }
                }
            }
        }
        
        // স্কোর = মিল সংখ্যা / মোট ইউজার শব্দ
        const score = userWords.length > 0 ? matchCount / userWords.length : 0;
        
        return {
            score: score,
            matchedWords: matchedWords,
            totalUserWords: userWords.length,
            totalStoredWords: storedWords.length
        };
    }

    // বেস্ট ম্যাচ খোঁজা - সব রেকর্ড থেকে
    function findBestMatch(question) {
        const allMatches = [];
        
        // সব ক্যাটাগরি থেকে খোঁজা
        for (let category in knowledgeBase) {
            for (let q in knowledgeBase[category]) {
                const matchResult = getWordMatchScore(question, q);
                if (matchResult.score > 0) {
                    allMatches.push({
                        category: category,
                        question: q,
                        answer: knowledgeBase[category][q],
                        score: matchResult.score,
                        matchedWords: matchResult.matchedWords,
                        totalUserWords: matchResult.totalUserWords,
                        totalStoredWords: matchResult.totalStoredWords
                    });
                }
            }
        }
        
        // স্কোর অনুযায়ী সর্ট (সর্বোচ্চ প্রথমে)
        allMatches.sort((a, b) => b.score - a.score);
        
        return allMatches;
    }

    // লোকাল স্টোরেজ - অপরিবর্তিত
    function loadFromLocalStorage() {
        try {
            const data = localStorage.getItem('chatbot_knowledge');
            if (data) knowledgeBase = JSON.parse(data);
            console.log('📦 লোকাল ডাটা লোড হয়েছে');
        } catch(e) {
            console.error('❌ লোকাল ডাটা লোড ত্রুটি:', e);
        }
    }

    function saveToLocalStorage() {
        try {
            localStorage.setItem('chatbot_knowledge', JSON.stringify(knowledgeBase));
        } catch(e) {
            console.error('❌ লোকাল ডাটা সেভ ত্রুটি:', e);
        }
    }

    function savePendingToLocal() {
        try {
            localStorage.setItem('chatbot_pending', JSON.stringify(pendingQuestions));
        } catch(e) {
            console.error('❌ পেন্ডিং সেভ ত্রুটি:', e);
        }
    }

    function updatePendingCount() {
        const count = pendingQuestions.length;
        document.getElementById('pendingCount').textContent = count;
        document.getElementById('adminPendingCount').textContent = count;
        
        if (count > 0) {
            const badge = document.querySelector('.pending-badge');
            if (badge) {
                badge.style.animation = 'none';
                badge.offsetHeight;
                badge.style.animation = 'pulse 0.5s ease';
            }
        }
    }

    // শীট থেকে ডাটা লোড - অপরিবর্তিত
    async function loadFromSheet() {
        try {
            const timestamp = new Date().getTime();
            const url = `${SCRIPT_URL}?action=getAll&t=${timestamp}`;
            console.log('📡 শীট থেকে ডাটা লোড হচ্ছে...');
            
            const response = await fetch(url);
            const result = await response.json();
            console.log('📥 শীট থেকে ডাটা:', result);
            
            if (result && result.success && result.data) {
                if (result.data.records) {
                    organizeSheetData(result.data.records);
                }
                if (result.data.pending) {
                    pendingQuestions = result.data.pending;
                    savePendingToLocal();
                    updatePendingCount();
                }
            }
        } catch(e) {
            console.log('⚠️ শীট লোড ব্যর্থ, লোকাল ডাটা ব্যবহার করা হবে');
        }
    }

    function organizeSheetData(records) {
        records.forEach(record => {
            if (!record.question || !record.answer) return;
            const category = record.category || 'general';
            if (!knowledgeBase[category]) knowledgeBase[category] = {};
            knowledgeBase[category][normalizeText(record.question)] = record.answer;
        });
        saveToLocalStorage();
    }

    // শীটে ডাটা সেভ - অপরিবর্তিত
    async function saveToSheet(action, category, question, answer) {
        try {
            const postData = {
                action: action,
                category: category || 'general',
                question: question || '',
                answer: answer || ''
            };
            
            console.log('📤 শীটে পাঠানো হচ্ছে:', JSON.stringify(postData));
            
            const response = await fetch(SCRIPT_URL, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: JSON.stringify(postData)
            });
            
            const result = await response.json();
            console.log('📥 সেভ রেসপন্স:', result);
            
            if (result.success) {
                console.log('✅ শীটে সফলভাবে সেভ হয়েছে');
                return true;
            } else {
                console.error('❌ শীট সেভ ত্রুটি:', result.error);
                return false;
            }
        } catch(e) {
            console.error('❌ শীট সেভ ব্যর্থ:', e.message);
            
            try {
                await fetch(SCRIPT_URL, {
                    method: 'POST',
                    mode: 'no-cors',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: JSON.stringify({
                        action: action,
                        category: category,
                        question: question,
                        answer: answer
                    })
                });
                console.log('✅ ফ্যালব্যাক সেভ সম্পন্ন');
                return true;
            } catch(e2) {
                console.error('❌ ফ্যালব্যাক সেভও ব্যর্থ:', e2.message);
                return false;
            }
        }
    }

    // স্কিপ ফাংশন
    window.skipAnswer = function() {
        if (waitingForAnswer) {
            waitingForAnswer = false;
            const skippedQuestion = lastQuestion;
            lastQuestion = '';
            
            console.log('⏭️ স্কিপ করা হয়েছে:', skippedQuestion);
            
            // স্কিপ মেসেজ অপশনালি সেভ (পেন্ডিং হিসেবে থেকে যাবে)
            addBotMessage(`👌 <strong>ঠিক আছে, "${skippedQuestion}" প্রশ্নের উত্তর দেওয়া স্কিপ করা হয়েছে।</strong><br/><br/>
                ✅ আপনি এখন নতুন প্রশ্ন করতে পারেন।<br/>
                📋 প্রশ্নটি অপেক্ষমাণ তালিকায় থাকবে, পরে উত্তর দিতে পারবেন।<br/><br/>
                <em>নতুন প্রশ্ন লিখুন, আমি সাহায্য করতে প্রস্তুত! 😊</em>`);
        }
    };
    
    // স্কিপ এবং নতুন প্রশ্ন
    window.skipAndAskNew = function() {
        window.skipAnswer();
        document.getElementById('userInput').focus();
    };

    // প্রসেসিং ইন্ডিকেটর
    function showProcessingIndicator(text) {
        const container = document.getElementById('messagesContainer');
        const indicatorDiv = document.createElement('div');
        indicatorDiv.className = 'message-row bot';
        indicatorDiv.id = 'processingIndicator';
        indicatorDiv.innerHTML = `
            <div class="bot-avatar small"><i class="fas fa-robot"></i></div>
            <div class="processing-indicator">
                <div class="brain-wave">
                    <span></span><span></span><span></span><span></span><span></span>
                </div>
                <span class="processing-text">${text || 'চিন্তা করছি...'}</span>
            </div>`;
        container.appendChild(indicatorDiv);
        container.scrollTop = container.scrollHeight;
    }

    function updateProcessingText(text) {
        const indicator = document.getElementById('processingIndicator');
        if (indicator) {
            const textEl = indicator.querySelector('.processing-text');
            if (textEl) textEl.textContent = text;
        }
    }

    function hideProcessingIndicator() {
        const indicator = document.getElementById('processingIndicator');
        if (indicator) indicator.remove();
    }

    // ওয়েলকাম মেসেজ হাইড
    function hideWelcome() {
        const welcome = document.getElementById('welcomeSection');
        if (welcome) {
            welcome.style.opacity = '0';
            welcome.style.transform = 'translateY(-20px)';
            welcome.style.transition = 'all 0.5s ease';
            setTimeout(() => {
                if (welcome.parentNode) welcome.remove();
            }, 500);
        }
    }

    // মেসেজ দেখানো
    function addMessage(text, isUser, extraClass) {
        hideWelcome();
        
        const container = document.getElementById('messagesContainer');
        const row = document.createElement('div');
        row.className = `message-row ${isUser ? 'user' : 'bot'}`;
        
        const now = new Date();
        const timeString = now.toLocaleTimeString('bn-BD', { hour: '2-digit', minute: '2-digit' });
        
        if (isUser) {
            row.innerHTML = `
                <div class="message-bubble ${extraClass || ''}">
                    ${escapeHtml(text)}
                    <div class="message-timestamp">
                        <i class="fas fa-check" style="font-size:0.6rem;"></i> ${timeString}
                    </div>
                </div>`;
        } else {
            row.innerHTML = `
                <div class="bot-avatar"><i class="fas fa-robot"></i></div>
                <div class="message-bubble ${extraClass || ''}">
                    ${text}
                    <div class="message-timestamp">
                        <i class="fas fa-clock" style="font-size:0.6rem;"></i> ${timeString}
                    </div>
                </div>`;
        }
        
        container.appendChild(row);
        container.scrollTop = container.scrollHeight;
        row.scrollIntoView({ behavior: 'smooth', block: 'end' });
    }

    function addBotMessage(text, extraClass) {
        addMessage(text, false, extraClass);
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function getCategoryName(cat) {
        const names = {
            'general': 'সাধারণ জিজ্ঞাসা',
            'technology': 'প্রযুক্তি',
            'education': 'শিক্ষা',
            'health': 'স্বাস্থ্য',
            'science': 'বিজ্ঞান'
        };
        return names[cat] || cat;
    }

    // প্রশ্ন প্রসেসিং - আপডেটেড ওয়ার্ড ম্যাচিং সহ
    async function processQuestion(userQuestion) {
        if (!userQuestion || userQuestion.trim() === '') {
            addBotMessage('😊 দয়া করে একটি প্রশ্ন লিখুন। আমি আপনার সাহায্যের জন্য প্রস্তুত আছি!');
            return;
        }
        
        // ★★★ যদি স্কিপ স্টেটে থাকে এবং ইউজার নতুন প্রশ্ন করে ★★★
        if (waitingForAnswer) {
            console.log('🔄 ইউজার স্কিপ না করে নতুন প্রশ্ন করেছে, আগের প্রশ্নের উত্তর হিসেবে নিচ্ছে না');
            
            // আগের প্রশ্ন পেন্ডিংয়ে থাকবে, স্কিপ স্টেট ক্লিয়ার
            waitingForAnswer = false;
            lastQuestion = '';
            
            // নতুন প্রশ্ন হিসেবে প্রসেস করুন (নিচে চলবে)
        }
        
        // এখন নতুন প্রশ্ন প্রসেস করুন
        return await processNewQuestion(userQuestion);
    }
    
    // নতুন প্রশ্ন প্রসেসিং - ওয়ার্ড ম্যাচিং সহ
    async function processNewQuestion(userQuestion) {
        const matches = findBestMatch(userQuestion);
        
        // ★★★ যদি ভালো ম্যাচ পাওয়া যায় (স্কোর >= 0.3) ★★★
        if (matches.length > 0 && matches[0].score >= 0.3) {
            const bestMatch = matches[0];
            const matchPercent = Math.round(bestMatch.score * 100);
            
            updateProcessingText('সবচেয়ে প্রাসঙ্গিক উত্তর খুঁজে পেয়েছি!');
            await new Promise(resolve => setTimeout(resolve, 300));
            hideProcessingIndicator();
            
            let responseHTML = `🎯 <strong>আপনার প্রশ্নের সাথে মিল রেখে উত্তর পেয়েছি!</strong><br/><br/>`;
            responseHTML += `<strong>📝 আপনার প্রশ্ন:</strong> ${userQuestion}<br/>`;
            responseHTML += `<strong>📌 মিলেছে:</strong> "${bestMatch.question}" (${matchPercent}% মিল)<br/><br/>`;
            responseHTML += `<strong>💡 উত্তর:</strong><br/>${bestMatch.answer}<br/><br/>`;
            
            // ম্যাচিং ওয়ার্ড দেখান
            if (bestMatch.matchedWords.length > 0) {
                responseHTML += `<em style="font-size:0.8rem;">🔗 মিলেছে শব্দ: ${bestMatch.matchedWords.join(', ')}</em><br/>`;
            }
            
            // ★★★ যদি একাধিক ভালো ম্যাচ থাকে, বিকল্প দেখান ★★★
            if (matches.length > 1 && matches[1].score >= 0.2) {
                responseHTML += `<div class="alt-answers">`;
                responseHTML += `<div class="alt-title">📋 আরও প্রাসঙ্গিক উত্তর:</div>`;
                
                for (let i = 1; i < Math.min(matches.length, 4); i++) {
                    const alt = matches[i];
                    const altPercent = Math.round(alt.score * 100);
                    responseHTML += `<div class="alt-answer-item" onclick='showAlternativeAnswer(${JSON.stringify(alt.answer).replace(/'/g, "&#39;")})'>
                        <span class="match-score">${altPercent}% মিল</span> - ${alt.answer.substring(0, 80)}...
                    </div>`;
                }
                
                responseHTML += `</div>`;
            }
            
            responseHTML += `<br/><em style="font-size:0.8rem;">আরও কিছু জানতে চাইলে বলুন! 🌟</em>`;
            
            addBotMessage(responseHTML);
            return;
        }
        
        // ★★★ যদি কম ম্যাচ পাওয়া যায় (স্কোর < 0.3 কিন্তু > 0) ★★★
        if (matches.length > 0 && matches[0].score > 0) {
            const weakMatch = matches[0];
            const matchPercent = Math.round(weakMatch.score * 100);
            
            updateProcessingText('আংশিক মিল পেয়েছি, যাচাই করছি...');
            await new Promise(resolve => setTimeout(resolve, 300));
            hideProcessingIndicator();
            
            let responseHTML = `🤔 <strong>আপনার প্রশ্নের সাথে আংশিক মিল পেয়েছি, কিন্তু পুরোপুরি নিশ্চিত নই।</strong><br/><br/>`;
            responseHTML += `<strong>📝 আপনার প্রশ্ন:</strong> ${userQuestion}<br/>`;
            responseHTML += `<strong>🔍 সবচেয়ে কাছাকাছি:</strong> "${weakMatch.question}" (${matchPercent}% মিল)<br/><br/>`;
            responseHTML += `<strong>💡 সম্ভাব্য উত্তর:</strong><br/>${weakMatch.answer}<br/><br/>`;
            responseHTML += `<em>❓ যদি এটি সঠিক না হয়, দয়া করে আরেকটু বিস্তারিত প্রশ্ন করুন অথবা অন্য প্রশ্ন করুন।</em><br/><br/>`;
            
            // বিকল্প দেখান
            if (matches.length > 1) {
                responseHTML += `<div class="alt-answers">`;
                responseHTML += `<div class="alt-title">📋 অন্যান্য সম্ভাব্য উত্তর:</div>`;
                
                for (let i = 1; i < Math.min(matches.length, 4); i++) {
                    const alt = matches[i];
                    const altPercent = Math.round(alt.score * 100);
                    responseHTML += `<div class="alt-answer-item">
                        <span class="match-score">${altPercent}% মিল</span> - ${alt.answer.substring(0, 80)}...
                    </div>`;
                }
                
                responseHTML += `</div>`;
            }
            
            responseHTML += `
                <div class="skip-btn-container">
                    <button class="skip-btn" onclick="skipAndAskNew()">
                        <i class="fas fa-times-circle"></i> ভুল উত্তর, নতুন প্রশ্ন করবো
                    </button>
                </div>`;
            
            addBotMessage(responseHTML);
            return;
        }
        
        // ★★★ কোন ম্যাচ পাওয়া যায়নি ★★★
        updateProcessingText('কোনো উত্তর খুঁজে পাইনি, সংরক্ষণ করছি...');
        await new Promise(resolve => setTimeout(resolve, 300));
        hideProcessingIndicator();
        
        console.log('➕ পেন্ডিংয়ে যোগ করা হচ্ছে:', userQuestion, 'ক্যাটাগরি:', currentCategory);
        
        await saveToSheet('addPending', currentCategory, userQuestion, '');
        
        pendingQuestions.push({
            category: currentCategory,
            question: userQuestion,
            timestamp: new Date().toISOString()
        });
        savePendingToLocal();
        updatePendingCount();
        
        waitingForAnswer = true;
        lastQuestion = userQuestion;
        
        let responseHTML = `🤔 <strong>মাফ করবেন, আমি এখনো "${userQuestion}" এই প্রশ্নের উত্তর জানি না।</strong><br/><br/>`;
        responseHTML += `📋 তবে চিন্তার কিছু নেই! প্রশ্নটি আমি "<strong>${getCategoryName(currentCategory)}</strong>" বিষয়ের অধীনে সংরক্ষণ করে রেখেছি।<br/><br/>`;
        responseHTML += `💡 <strong>আপনি চাইলে আমাকে শিখিয়ে দিতে পারেন!</strong> শুধু পরবর্তী মেসেজে উত্তরটি লিখে পাঠান, আমি তা মনে রাখবো।<br/><br/>`;
        responseHTML += `
            <div class="skip-btn-container">
                <button class="skip-btn primary-skip" onclick="skipAndAskNew()">
                    <i class="fas fa-forward"></i> স্কিপ করুন, নতুন প্রশ্ন করবো
                </button>
                <button class="skip-btn" onclick="window.skipAnswer(); document.getElementById('userInput').focus();">
                    <i class="fas fa-question-circle"></i> উত্তর দিতে চাই না
                </button>
            </div>`;
        responseHTML += `<br/><em style="font-size:0.85rem;">আমি সবসময় নতুন কিছু শিখতে আগ্রহী! 📚</em>`;
        
        addBotMessage(responseHTML);
    }

    // প্রশ্ন জিজ্ঞাসা
    window.askQuestion = function(question) {
        const input = document.getElementById('userInput');
        input.value = question;
        input.focus();
        handleSend();
    };

    // মেসেজ সেন্ড
    window.handleSend = async function() {
        if (isProcessing) return;
        
        const input = document.getElementById('userInput');
        const question = input.value.trim();
        
        if (!question) {
            input.placeholder = '⚠️ প্রথমে একটি প্রশ্ন লিখুন!';
            input.focus();
            setTimeout(() => {
                input.placeholder = 'এখানে আপনার প্রশ্ন লিখুন...';
            }, 2000);
            return;
        }
        
        isProcessing = true;
        
        // ★★★ স্কিপ স্টেটে থাকলে এবং ইউজার উত্তর না দিয়ে নতুন প্রশ্ন করলে ★★★
        if (waitingForAnswer) {
            console.log('⏭️ ইউজার স্কিপ স্টেটে নতুন প্রশ্ন করেছে - আগের প্রশ্নের উত্তর হিসেবে নিচ্ছে না');
            // waitingForAnswer এবং lastQuestion প্রসেস হবে processQuestion এর ভিতরে
        }
        
        addMessage(question, true);
        input.value = '';
        input.focus();
        
        // প্রসেসিং স্টেপ
        showProcessingIndicator('আপনার প্রশ্ন বিশ্লেষণ করছি...');
        await new Promise(resolve => setTimeout(resolve, 500 + Math.random() * 300));
        
        updateProcessingText('শব্দ মিলিয়ে উত্তর খুঁজছি...');
        await new Promise(resolve => setTimeout(resolve, 400 + Math.random() * 200));
        
        await processQuestion(question);
        
        hideProcessingIndicator();
        isProcessing = false;
    };

    // অ্যাডমিন প্যানেল
    window.openAdminPanel = function() {
        const modal = document.getElementById('adminModal');
        modal.classList.add('active');
        renderPendingQuestions();
        document.body.style.overflow = 'hidden';
        
        document.addEventListener('keydown', handleEscKey);
    };

    window.closeAdminPanel = function() {
        const modal = document.getElementById('adminModal');
        modal.classList.remove('active');
        document.body.style.overflow = '';
        
        document.removeEventListener('keydown', handleEscKey);
    };

    function handleEscKey(e) {
        if (e.key === 'Escape') {
            closeAdminPanel();
        }
    }

    function renderPendingQuestions() {
        const container = document.getElementById('pendingQuestionsList');
        
        if (pendingQuestions.length === 0) {
            container.innerHTML = `
                <p style='color:#64748b; text-align:center; padding:40px 20px; font-size:1.05rem;'>
                    <i class='fas fa-check-circle' style='font-size:3rem; color:#10b981; display:block; margin-bottom:14px;'></i>
                    <strong>সব উত্তর দিয়ে ফেলেছেন!</strong><br/>
                    <span style='font-size:0.9rem;'>কোনো অপেক্ষমাণ প্রশ্ন নেই 🎉</span>
                </p>`;
            return;
        }
        
        container.innerHTML = pendingQuestions.map((item, index) => `
            <div class="pending-question">
                <div class="question-text">
                    <span class="category-tag">
                        ${getCategoryName(item.category)}
                    </span>
                    <span>${escapeHtml(item.question)}</span>
                </div>
                <textarea class="answer-input" placeholder="✍️ এখানে উত্তর লিখুন..." id="answerInput${index}" rows="3"></textarea>
                <div class="button-group">
                    <button class="save-answer-btn" onclick="saveAnswerFromAdmin(${index})">
                        <i class="fas fa-save"></i> সংরক্ষণ করুন
                    </button>
                    <button class="delete-btn" onclick="removePending(${index})">
                        <i class="fas fa-trash"></i> মুছে ফেলুন
                    </button>
                </div>
            </div>
        `).join('');
    }

    window.saveAnswerFromAdmin = async function(index) {
        const answerInput = document.getElementById(`answerInput${index}`);
        const answer = answerInput.value.trim();
        
        if (!answer) {
            answerInput.style.borderColor = '#f43f5e';
            answerInput.style.boxShadow = '0 0 0 4px rgba(244, 63, 94, 0.1)';
            answerInput.placeholder = '⚠️ দয়া করে প্রথমে উত্তর লিখুন!';
            answerInput.focus();
            
            setTimeout(() => {
                answerInput.style.borderColor = '#e2e8f0';
                answerInput.style.boxShadow = 'none';
                answerInput.placeholder = '✍️ এখানে উত্তর লিখুন...';
            }, 2500);
            return;
        }
        
        const item = pendingQuestions[index];
        const btn = event.target.closest('.save-answer-btn');
        if (btn) {
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> সংরক্ষণ হচ্ছে...';
            btn.disabled = true;
        }
        
        await saveToSheet('addRecord', item.category, item.question, answer);
        
        if (!knowledgeBase[item.category]) knowledgeBase[item.category] = {};
        knowledgeBase[item.category][normalizeText(item.question)] = answer;
        saveToLocalStorage();
        
        pendingQuestions.splice(index, 1);
        savePendingToLocal();
        updatePendingCount();
        renderPendingQuestions();
        
        // স্কিপ স্টেট রিসেট যদি এইটা সেই প্রশ্ন হয়
        if (waitingForAnswer && lastQuestion === item.question) {
            waitingForAnswer = false;
            lastQuestion = '';
        }
        
        console.log('✅ উত্তর সফলভাবে সংরক্ষিত হয়েছে!');
    };

    window.removePending = function(index) {
        const item = pendingQuestions[index];
        
        if (confirm('🗑️ আপনি কি নিশ্চিত যে এই প্রশ্নটি মুছে ফেলতে চান?\n\nএটি স্থায়ীভাবে মুছে যাবে।')) {
            // স্কিপ স্টেট রিসেট যদি এইটা সেই প্রশ্ন হয়
            if (waitingForAnswer && lastQuestion === item.question) {
                waitingForAnswer = false;
                lastQuestion = '';
            }
            
            pendingQuestions.splice(index, 1);
            savePendingToLocal();
            updatePendingCount();
            renderPendingQuestions();
            
            console.log('🗑️ প্রশ্ন মুছে ফেলা হয়েছে');
        }
    };

    // ইভেন্ট লিসেনার
    const userInput = document.getElementById('userInput');
    
    userInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            handleSend();
        }
    });

    document.getElementById('adminModal').addEventListener('click', function(e) {
        if (e.target === this) closeAdminPanel();
    });

    document.addEventListener('click', function(e) {
        const tooltip = document.getElementById('helpTooltip');
        if (tooltip.style.display === 'block' && 
            !tooltip.contains(e.target) && 
            !e.target.closest('.subject-chip[onclick*="showHelp"]')) {
            hideHelp();
        }
    });

    window.addEventListener('resize', function() {
        const sidebar = document.getElementById('sidebarPanel');
        if (window.innerWidth > 768) {
            sidebar.style.boxShadow = 'none';
            sidebar.classList.remove('collapsed');
        } else {
            sidebar.classList.add('collapsed');
        }
    });

    // পেজ লোড/রিলোড হলে স্কিপ স্টেট রিসেট
    window.addEventListener('beforeunload', function() {
        waitingForAnswer = false;
        lastQuestion = '';
    });

    // ম্যানুয়াল টেস্ট ফাংশন - অপরিবর্তিত
    window.testSheetConnection = async function() {
        console.log('🧪 শীট সংযোগ পরীক্ষা করা হচ্ছে...');
        
        const testQuestion = "টেস্ট প্রশ্ন " + new Date().toISOString();
        const testCategory = "general";
        
        console.log('পরীক্ষা করা হচ্ছে:', testQuestion);
        
        await saveToSheet('addPending', testCategory, testQuestion, '');
        console.log('✅ পরীক্ষা সম্পন্ন। পেন্ডিং শীট চেক করুন।');
    };

    // ইনিশিয়ালাইজ
    init();
    console.log('✅ চ্যাটবট সফলভাবে চালু হয়েছে!');
    console.log('📋 পরীক্ষা করতে: testSheetConnection()');
    console.log('⏭️ স্কিপ ফিচার: skipAnswer() বা skipAndAskNew()');
    console.log('🔍 ওয়ার্ড ম্যাচিং অ্যাক্টিভ');
})();
// ]]>
</script>
<div id='connectionStatus' style='display:none'/>
</body>
</html>
